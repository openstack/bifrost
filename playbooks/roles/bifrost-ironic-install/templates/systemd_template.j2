[Unit]
Description={{ service_name }} service

[Service]
Type=notify
ExecStart={{ service_path }}/{{ service_name }} --config-file {{ config_file }} {% if config_dir is defined %} --config-dir {{ config_dir }} {% endif %}

User=ironic
RuntimeDirectory=ironic
RuntimeDirectoryMode=750
RuntimeDirectoryPreserve=yes
Restart=on-failure

[Install]
WantedBy=multi-user.target
Alias={{ service_name }}.service
